<h1>Nuestra Tienda</h1>
{{#each products}}
    <div>
        <h3>{{this.title}}</h3>
        <p>Precio: ${{this.price}}</p>
        <button>Agregar al Carrito</button>
    </div>
{{/each}}

<div>
    {{#if hasPrevPage}}
        <a href="/products?page={{prevPage}}">Anterior</a>
    {{/if}}
    
    <span>Página {{currentPage}}</span>

    {{#if hasNextPage}}
        <a href="/products?page={{nextPage}}">Siguiente</a>
    {{/if}}
</div>